<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="ic_launcher_background">#1B2A52</color>
    <color name="sentinela_flame_red">#E8401E</color>
    <color name="sentinela_navy">#1B2A52</color>
    <string name="app_name">Sentinela</string>
    <string name="notification_channel_desc">Avisos quando um foco de calor entra no raio de um ponto monitorado</string>
    <string name="notification_channel_name">Alertas de proximidade</string>
    <string name="notification_proximity_body">Foco a %1$.1f km de %2$s</string>
    <string name="notification_proximity_title">⚠️ Alerta Sentinela</string>
    <style name="Theme.Sentinela" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/sentinela_navy</item>
        <item name="android:navigationBarColor">@color/sentinela_navy</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
    <style name="Theme.Sentinela.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/sentinela_navy</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/sentinela_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.Sentinela</item>
    </style>
</resources>